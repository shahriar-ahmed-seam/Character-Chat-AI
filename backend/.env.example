# ─────────────────────────────────────────────────────────────
# Character Chat AI — backend environment configuration
# Copy this file to `.env` and fill in real values.
# Never commit the real `.env` file (it is git-ignored).
# ─────────────────────────────────────────────────────────────

# --- Database ---
# Local dev (zero setup, works out of the box):
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Production (Neon) — paste the connection string from the Neon dashboard.
# The app auto-converts a `postgresql://...` URL to the async driver.
# DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# --- LLM Provider (OpenAI-compatible) ---
# Local dev with Ollama:
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_CHAT_MODEL=gemma3:4b
LLM_EMBED_MODEL=nomic-embed-text
LLM_API_KEY=ollama
# Production example (Groq):
# LLM_PROVIDER=groq
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_CHAT_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=gsk_xxx

# --- Memory ---
SHORT_TERM_N=20
LONG_TERM_MEMORY_ENABLED=false

# --- LLM request timeout (seconds) ---
# 30 is the production target (fast hosted providers). Local CPU inference of a 4B
# model is much slower, so raise this for local development.
LLM_TIMEOUT_SECONDS=120

# --- API security (Phase 5) ---
# Comma-separated list of valid API keys clients must send.
API_KEYS=dev-local-key
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
# Set to false during early local dev to skip auth; true in production.
AUTH_ENABLED=false

# --- Personas ---
# Directory containing persona JSON definitions (relative to backend/).
PERSONA_DIR=app/personas/data

# --- Telegram bot (Phase 3, optional) ---
# Leave blank to keep the Telegram webhook disabled. Set from BotFather to enable.
TELEGRAM_BOT_TOKEN=
# A random secret you choose; Telegram echoes it back in a header so you can verify
# that webhook calls really come from Telegram.
TELEGRAM_WEBHOOK_SECRET=
